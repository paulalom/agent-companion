{
  "servers": [
    {
      "id": "codex-local",
      "name": "Codex Local",
      "kind": "agent-telemetry",
      "command": "${nodeRuntime}",
      "args": [
        "${resources}/mcp-codex/index.mjs"
      ],
      "env": {
        "CODEX_HOME": "${home}/.codex",
        "ELECTRON_RUN_AS_NODE": "1"
      },
      "usageTool": "get_usage_snapshot"
    }
  ]
}
